{
  "mcpServers": {
    "skillmon-sqlite": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-sqlite",
        "${MCP_SQLITE_DB_PATH:-~/.local/share/com.skillmon/database.sqlite}"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    }
  }
}
